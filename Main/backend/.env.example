# TalentAlign Backend — Environment Variable Template
#
# Copy this file to .env and fill in real values for local dev.
# DO NOT commit .env — it is .gitignored.

# ── LLM backend selection ────────────────────────────────────────────────────
# Auto cascade: gemini (if key set) → none. Set explicitly to override:
#   gemini  — production / dev with a real Gemini API key
#   mock    — fixture-based, used in tests
#   none    — deterministic SBERT-only mode (no LLM calls)
LLM_BACKEND=gemini

# Gemini API key — either GEMINI_API_KEY or GOOGLE_API_KEY works.
# Required when LLM_BACKEND=gemini.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional Gemini tuning
# TALENTALIGN_LLM_MODEL=gemini-2.5-flash
# TALENTALIGN_LLM_TIMEOUT=15
# TALENTALIGN_LLM_COST_CAP=0.10
# TALENTALIGN_LLM_CACHE_DIR=.cache/talentalign-llm

# Match-validation gate tuning (defaults shown)
# TALENTALIGN_LLM_VALIDATE_LOW=0.45
# TALENTALIGN_LLM_VALIDATE_HIGH=0.75
# TALENTALIGN_LLM_VALIDATE_TIERS=semantic,partial
# TALENTALIGN_LLM_REJECT_CONFIDENCE=0.7

# ── Embeddings ───────────────────────────────────────────────────────────────
# Embedding backend override. Default cascade: sbert → tfidf → token.
# Force a backend for CI / fast tests:
#   sbert | tfidf | token
# TALENTALIGN_EMBEDDING_BACKEND=

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the FastAPI app.
# Default: http://localhost:3000 (Next.js dev server).
# Production: set to your Vercel/Netlify origin(s).
TALENTALIGN_CORS_ORIGINS=http://localhost:3000

# ── Scoring config override (optional) ───────────────────────────────────────
# Path to a custom weight_config.json. Default: app/core/weight_config.json.
# TALENTALIGN_WEIGHT_CONFIG_PATH=

# ── Optional / future ────────────────────────────────────────────────────────
# Groq backend (scaffolded, opt-in via LLM_BACKEND=groq + GROQ_API_KEY).
# GROQ_API_KEY=

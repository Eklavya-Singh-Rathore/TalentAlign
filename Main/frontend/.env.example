# TalentAlign Frontend — Environment Variable Template
#
# Copy this file to .env.local and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.

# ── API endpoint ─────────────────────────────────────────────────────────────
# Backend base URL. Local dev: http://localhost:8000.
# Production: your deployed FastAPI origin (e.g. https://api.talentalign.app).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
